@page "/rodina"
@{
    ViewData["Title"] = "Rodina";
}

<section class="family-hero">
  <div class="family-copy">
    <div class="badge">Rodina</div>
    <h1>A softer page with its own visual language.</h1>
    <p class="lead">
      Samostatná rodinná stránka s jemnějším tónem, kartami a prostorem pro osobnější obsah.
    </p>
  </div>
</section>

<section class="section">
  <div class="family-grid">
    <article class="family-member ester">
      <div class="card-kicker">Ester</div>
      <h2>Ester</h2>
      <p>Místo pro příběhy, fotky nebo malý timeline blok.</p>
    </article>

    <article class="family-member adam">
      <div class="card-kicker">Adam</div>
      <h2>Adam</h2>
      <p>Samostatná karta s vlastním akcentem a prostorem na obsah.</p>
    </article>

    <article class="family-member ema">
      <div class="card-kicker">Ema</div>
      <h2>Ema</h2>
      <p>Klidně sem později doplň galerii, poznámky nebo oblíbená místa.</p>
    </article>
  </div>
</section>
