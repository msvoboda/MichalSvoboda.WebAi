@page "/rodina"
@{
    ViewData["Title"] = "Family";
}

<section class="family-hero">
  <div class="family-copy">
    <div class="badge">Family</div>
    <h1>A softer page with its own visual language.</h1>
    <p class="lead">
      A dedicated family page with a softer tone, cards, and space for more personal content.
    </p>
  </div>
</section>

<section class="section">
  <div class="family-grid">
    <article class="family-member ester">
      <div class="card-kicker">Ester</div>
      <h2>Ester</h2>
      <p>Space for stories, photos, or a small timeline block.</p>
    </article>

    <article class="family-member adam">
      <div class="card-kicker">Adam</div>
      <h2>Adam</h2>
      <p>A dedicated card with its own accent and room for content.</p>
    </article>

    <article class="family-member ema">
      <div class="card-kicker">Ema</div>
      <h2>Ema</h2>
      <p>A place to add a gallery, notes, or favorite places later.</p>
    </article>
  </div>
</section>
