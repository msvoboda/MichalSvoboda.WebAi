@page "/videos"
@model MichalSvoboda.Web.Pages.VideosModel
@{
    ViewData["Title"] = "Michal Svoboda - Videos";
}

<section class="section videos-section">
  <div class="videos-header">
    <div>
      <div class="badge">Video Library</div>
      <h1>Videos from the FTP folder</h1>
    </div>
    <p class="lead">
      Upload a video file to <code>wwwroot/videos</code> and it will appear here automatically.
      The direct video URL will also work outside this website.
    </p>
  </div>

  @if (Model.Videos.Count == 0)
  {
    <article class="card">
      <h2>No videos yet</h2>
      <p class="muted">
        Upload a <code>.mp4</code>, <code>.webm</code>, <code>.mov</code>, <code>.m4v</code>, or <code>.ogg</code>
        file to <code>wwwroot/videos</code>.
      </p>
    </article>
  }
  else
  {
    <div class="videos-grid">
      @foreach (var video in Model.Videos)
      {
        <article class="card video-card">
          <div class="video-frame">
            <video controls preload="metadata" playsinline>
              <source src="@video.Url" type="@video.ContentType" />
              Your browser does not support video playback.
            </video>
          </div>

          <div class="video-meta">
            <div>
              <h2>@video.DisplayName</h2>
              <div class="muted small">@video.FileName</div>
            </div>
            <div class="small muted">@video.SizeLabel</div>
          </div>

          <label class="video-link-label" for="@video.InputId">Direct URL</label>
          <input id="@video.InputId" class="video-link" type="text" value="@video.Url" readonly />

          <div class="cta">
            <a class="btn primary" href="@video.Url" target="_blank" rel="noreferrer">Open video</a>
          </div>
        </article>
      }
    </div>
  }
</section>
