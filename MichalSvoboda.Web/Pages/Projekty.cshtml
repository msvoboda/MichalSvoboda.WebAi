@page "/projekty"
@model MichalSvoboda.Web.Pages.ProjektyModel
@{
    ViewData["Title"] = "Projekty";
}

<section class="projects-hero">
  <div>
    <div class="badge">Osobní projekty</div>
    <h1>Projekty mimo práci – hry, nástroje a nápady.</h1>
    <p class="lead">
      Věci, které vznikly z nadšení, experimentování nebo potřeby. Od her po užitečné nástroje.
    </p>
  </div>
</section>

<section class="section">
  @if (Model.Projects.Count == 0)
  {
    <article class="spotlight">
      <h2>Zatím žádné projekty</h2>
      <p class="muted">Přidej projekty do souboru <code>wwwroot/data/projects.json</code>.</p>
    </article>
  }
  else
  {
    <div class="personal-projects-grid">
      @foreach (var project in Model.Projects)
      {
        <article class="project-card">
          @if (!string.IsNullOrEmpty(project.Image))
          {
            <div class="project-image">
              <img src="@project.Image" alt="@project.Name" loading="lazy" />
            </div>
          }
          else
          {
            <div class="project-image project-image-placeholder">
              <span>📦</span>
            </div>
          }
          <div class="project-body">
            <div class="project-header">
              <h2>@project.Name</h2>
              <span class="project-platform">@project.Platform</span>
            </div>
            <p class="project-description">@project.Description</p>
            <div class="project-stack">
              @foreach (var tech in project.TechStack)
              {
                <span class="chip">@tech</span>
              }
            </div>
            @if (!string.IsNullOrEmpty(project.Url) || !string.IsNullOrEmpty(project.DownloadUrl))
            {
              <div class="project-links">
                @if (!string.IsNullOrEmpty(project.Url))
                {
                  <a class="btn primary" href="@project.Url" target="_blank" rel="noopener noreferrer">Zobrazit ↗</a>
                }
                @if (!string.IsNullOrEmpty(project.DownloadUrl))
                {
                  <a class="btn" href="@project.DownloadUrl" target="_blank" rel="noopener noreferrer">Stáhnout ↓</a>
                }
              </div>
            }
          </div>
        </article>
      }
    </div>
  }
</section>
