@page "/projekty"
@{
    ViewData["Title"] = "Projects";
}

<section class="projects-hero">
  <div>
    <div class="badge">Projects</div>
    <h1>Engineering work presented as a dedicated showcase.</h1>
    <p class="lead">
      A dedicated project portfolio page, not just another section on the homepage.
    </p>
  </div>
</section>

<section class="section">
  <div class="stack">
    <article class="work spotlight">
      <div class="workhead">
        <h2>Internal AI Team</h2>
        <div class="muted">Python • Azure AI • LLMs</div>
      </div>
      <ul>
        <li>Enhanced chatbot capabilities with advanced reasoning.</li>
        <li>Document analysis and information extraction from structured and unstructured sources.</li>
        <li>End-to-end AI solutions in Azure including orchestration, monitoring, and lifecycle design.</li>
      </ul>
    </article>

    <article class="work spotlight">
      <div class="workhead">
        <h2>Public Sector API Modernisation</h2>
        <div class="muted">Java 17 • REST • Security • Caching</div>
      </div>
      <ul>
        <li>Modern REST API implementation with strong security and operational reliability.</li>
        <li>Background jobs, caching strategy, and maintainable integration contracts.</li>
        <li>Support for Python modules used in complex testing automation.</li>
      </ul>
    </article>

    <article class="work spotlight">
      <div class="workhead">
        <h2>GDPR Workflow Platform</h2>
        <div class="muted">Kotlin • Camunda • PostgreSQL</div>
      </div>
      <ul>
        <li>Main developer for GDPR request processing with compliance focus.</li>
        <li>Integrations, monitoring, operational improvements, and incident solving in DevSecOps mode.</li>
      </ul>
    </article>
  </div>
</section>
